<+><!DOCTYPE html>\n<html lang=\"es\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>BlaBlaCat</title>\n    <link rel=\"stylesheet\" href=\"{{ url_for('static', filename='css/styles.css') }}\">\n</head>\n<body>\n\n    <!-- ══ Navbar ══════════════════════════════════════════ -->\n    <nav>\n        <a href=\"/\" onclick=\"navigate(event, '/')\" class=\"nav-logo\">\n            <img src=\"{{ url_for('static', filename='img/logo.png') }}\"\n                 alt=\"BlaBlaCat logo\"\n                 onerror=\"this.style.display='none'\">\n            <span class=\"nav-brand\">Bla<span>Bla</span>Cat</span>\n        </a>\n\n        <a href=\"/solicitudes\" onclick=\"navigate(event, '/solicitudes')\"\n           id=\"nav-solicitudes\" style=\"display:none\">Mis solicitudes</a>\n\n        <span id=\"nav-admin\" style=\"display:none\">\n            <a href=\"/admin/usuarios\"    onclick=\"navigate(event, '/admin/usuarios')\">\uD83D\uDC65 Usuarios</a>\n            <a href=\"/admin/solicitudes\" onclick=\"navigate(event, '/admin/solicitudes')\">\uD83D\uDC3E Mascotas</a>\n        </span>\n\n        <a href=\"/login\" onclick=\"navigate(event, '/login')\" id=\"nav-login\">Entrar</a>\n        <span id=\"nav-logout\" style=\"display:none\">\n            <span id=\"nav-username\"></span>\n            &nbsp;·&nbsp;\n            <a href=\"#\" onclick=\"logout()\">Salir</a>\n        </span>\n    </nav>\n\n    <!-- ══ SPA container ═══════════════════════════════════ -->\n    <main id=\"app\"></main>\n\n    <!-- ══════════════ TEMPLATES ══════════════════════════ -->\n\n    <template id=\"tpl-home\">\n        <section class=\"home-hero\">\n            <h1>La comunidad de<br><em>cuidadores de mascotas</em></h1>\n            <p>Conecta con personas de confianza que cuidarán a tu compañero como si fuera el suyo.</p>\n            <div class=\"home-cta\">\n                <a href=\"/registro\" onclick=\"navigate(event, '/registro')\" class=\"cta-main\">Empieza gratis</a>\n                <a href=\"/login\"    onclick=\"navigate(event, '/login')\"    class=\"cta-secondary\">Iniciar sesión</a>\n            </div>\n        </section>\n    </template>\n\n    <template id=\"tpl-login\">\n        <section class=\"auth-section\">\n            <h2>Iniciar sesión</h2>\n            <form id=\"form-login\">\n                <input type=\"email\"    name=\"email\"    placeholder=\"Email\"      required>\n                <input type=\"password\" name=\"password\" placeholder=\"Contraseña\" required>\n                <button type=\"submit\">Entrar</button>\n            </form>\n            <p>¿No tienes cuenta? <a href=\"/registro\" onclick=\"navigate(event, '/registro')\">Regístrate</a></p>\n        </section>\n    </template>\n\n    <template id=\"tpl-registro\">\n        <section class=\"auth-section\">\n            <h2>Crear cuenta</h2>\n            <form id=\"form-registro\">\n                <input type=\"text\"     name=\"username\" placeholder=\"Nombre de usuario\" required>\n                <input type=\"email\"    name=\"email\"    placeholder=\"Email\"             required>\n                <input type=\"password\" name=\"password\" placeholder=\"Contraseña\"        required>\n                <button type=\"submit\">Registrarse</button>\n            </form>\n            <p>¿Ya tienes cuenta? <a href=\"/login\" onclick=\"navigate(event, '/login')\">Inicia sesión</a></p>\n        </section>\n    </template>\n\n    <template id=\"tpl-solicitudes\">\n        <section>\n            <h2>Mis solicitudes</h2>\n            <form id=\"form-nueva-solicitud\">\n                <input type=\"text\" name=\"nombre\"  placeholder=\"Nombre de la mascota\" required>\n                <input type=\"text\" name=\"especie\" placeholder=\"Especie\"              required>\n                <input type=\"text\" name=\"raza\"    placeholder=\"Raza (opcional)\">\n                <button type=\"submit\">+ Nueva solicitud</button>\n            </form>\n            <ul id=\"lista-solicitudes\"></ul>\n        </section>\n    </template>\n\n    <template id=\"tpl-admin-usuarios\">\n        <section>\n            <h2>\uD83D\uDC65 Gestión de usuarios</h2>\n            <a href=\"/admin/solicitudes\" onclick=\"navigate(event, '/admin/solicitudes')\"\n               class=\"admin-back\">\uD83D\uDC3E Ver catálogo de mascotas →</a>\n            <table>\n                <thead>\n                    <tr><th>ID</th><th>Usuario</th><th>Email</th><th>Rol</th><th>Acción</th></tr>\n                </thead>\n                <tbody id=\"lista-admin-usuarios\">\n                    <tr><td colspan=\"5\">Cargando...</td></tr>\n                </tbody>\n            </table>\n        </section>\n    </template>\n\n    <template id=\"tpl-admin-solicitudes\">\n        <section>\n            <h2>\uD83D\uDC3E Catálogo de mascotas</h2>\n            <a href=\"/admin/usuarios\" onclick=\"navigate(event, '/admin/usuarios')\"\n               class=\"admin-back\">\uD83D\uDC65 Ver usuarios →</a>\n            <table>\n                <thead>\n                    <tr><th>ID</th><th>Foto</th><th>Nombre</th><th>Especie / Raza</th><th>Propietario</th><th>Inicio</th><th>Fin</th></tr>\n                </thead>\n                <tbody id=\"lista-admin-solicitudes\">\n                    <tr><td colspan=\"7\">Cargando...</td></tr>\n                </tbody>\n            </table>\n        </section>\n    </template>\n\n    <template id=\"tpl-404\">\n        <section style=\"text-align:center; padding:3rem 2rem;\">\n            <h2>\uD83D\uDC3E Página no encontrada</h2>\n            <p style=\"margin:1rem 0;\">Parece que esta huella no lleva a ningún sitio.</p>\n            <a href=\"/\" onclick=\"navigate(event, '/')\"\n               style=\"display:inline-block;margin-top:1rem;padding:.8rem 2rem;\n                      background:linear-gradient(135deg,#A0662A,#7B5EA7);\n                      color:#fff;border-radius:14px;font-weight:700;\">\n                Volver al inicio\n            </a>\n        </section>\n    </template>\n\n    <script src=\"{{ url_for('static', filename='js/auth.js') }}\"></script>\n    <script src=\"{{ url_for('static', filename='js/admin.js') }}\"></script>\n    <script src=\"{{ url_for('static', filename='js/solicitudes.js') }}\"></script>\n    <script src=\"{{ url_for('static', filename='js/app.js') }}\"></script>\n\n</body>\n</html>
